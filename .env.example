# Cyprus VIP Estates — environment template.
# Copy to .env.production (on the VPS) and fill in real values. NEVER commit the
# filled file — only this example is tracked. Generate secrets with: openssl rand -hex 32

# ─── Database (Prisma / PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cyprusvipestates"

# ─── Auth — NextAuth v5 (admin panel at /admin) ──────────────────────────────
AUTH_SECRET=                       # 32+ char random. Legacy alias NEXTAUTH_SECRET also accepted.
ADMIN_EMAIL=office@cyprusvipestates.com
# ADMIN_PASSWORD is consumed ONLY by prisma/seed-admin.mjs, and only to create
# this account if it doesn't exist yet — the script never overwrites an
# existing user's password. Set it for the very first run against a fresh
# database, then leave it unset (the admin's real password lives in the DB,
# changed through the panel, not here).
ADMIN_PASSWORD=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://cyprusvipestates.com

# ─── Email (SMTP) — lead notifications ───────────────────────────────────────
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=                          # lead-notification recipient
EMAIL_COFOUNDER=                   # optional second recipient

# ─── Telegram — lead notifications ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Scheduled publishing — cron worker auth ─────────────────────────────────
# Used by the VPS crontab to call /api/cron/publish-scheduled (Bearer header).
CRON_SECRET=

# ─── Self-hosted analytics ───────────────────────────────────────────────────
# Salts the daily-rotating, cookieless visitor hash (no IP/PII stored).
ANALYTICS_SALT=

# ─── Anti-spam debug (optional) ──────────────────────────────────────────────
ANTISPAM_DEBUG_TOKEN=              # optional; matches x-debug-token header on lead endpoints

# ─── Sanity (migration only — leave blank post-migration) ────────────────────
# Vestigial after the Prisma migration; the urlFor() shim references these names.
# SANITY_API_TOKEN was read-only and should be removed once migration is verified.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Google Search Console — /api/cron/gsc-sync (server-to-server, service account) ──
# Absolute path on the VPS to the downloaded service-account JSON key — NEVER
# commit the key itself, only this path. See docs/ setup guide for the
# one-time Google Cloud + Search Console console steps.
GSC_SERVICE_ACCOUNT_KEY_PATH=
# Exact property identifier as registered in Search Console — either a domain
# property ("sc-domain:cyprusvipestates.com") or a URL-prefix property
# ("https://cyprusvipestates.com/"). Passed straight through to the API.
GSC_SITE_PROPERTY=

# ─── Future SEO/local-search providers (foundation only, not yet configured) ─
# See src/lib/seo-sources/ — typed adapter stubs, no API calls implemented.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GBP_SERVICE_ACCOUNT_KEY_PATH=
GBP_LOCATION_ID=

# ─── PageSpeed Insights — /api/cron/psi-sync (plain API key, no service account) ─
PSI_API_KEY=

# ─── IndexNow — src/lib/indexnow.ts ──────────────────────────────────────────
# NOT a secret by protocol design: this exact value is also the content of the
# public key file at /<key>.txt (see public/), which search engines fetch to
# verify domain ownership. Safe to commit; rotate by generating a new key,
# adding a new public/<key>.txt, and updating this value together.
INDEXNOW_KEY=3499d71f004393c8d27c96caccbf03d1
