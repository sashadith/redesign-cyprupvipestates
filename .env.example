# Cyprus VIP Estates — environment template.
# Copy to .env.production (on the VPS) and fill in real values. NEVER commit the
# filled file — only this example is tracked. Generate secrets with: openssl rand -hex 32

# ─── Database (Prisma / PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cyprusvipestates"

# ─── Auth — NextAuth v5 (admin panel at /admin) ──────────────────────────────
AUTH_SECRET=                       # 32+ char random. Legacy alias NEXTAUTH_SECRET also accepted.
ADMIN_EMAIL=office@cyprusvipestates.com
ADMIN_PASSWORD=                    # initial admin user seed only (prisma/seed-admin)

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://cyprusvipestates.com

# ─── Email (SMTP) — lead notifications ───────────────────────────────────────
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=                          # lead-notification recipient
EMAIL_COFOUNDER=                   # optional second recipient

# ─── Telegram — lead notifications ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Scheduled publishing — cron worker auth ─────────────────────────────────
# Used by the VPS crontab to call /api/cron/publish-scheduled (Bearer header).
CRON_SECRET=

# ─── Self-hosted analytics ───────────────────────────────────────────────────
# Salts the daily-rotating, cookieless visitor hash (no IP/PII stored).
ANALYTICS_SALT=

# ─── Anti-spam debug (optional) ──────────────────────────────────────────────
ANTISPAM_DEBUG_TOKEN=              # optional; matches x-debug-token header on lead endpoints

# ─── Sanity (migration only — leave blank post-migration) ────────────────────
# Vestigial after the Prisma migration; the urlFor() shim references these names.
# SANITY_API_TOKEN was read-only and should be removed once migration is verified.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
