// PROPOSED Prisma schema — Cyprus VIP Estates (DRAFT for review, not yet applied)
// Design principles (from DECISIONS.md):
//  • Decision 1 — mirror Sanity: ONE ROW PER LANGUAGE, variants linked by translationGroupId
//  • Decision 2 — keep rich/nested content as native JSON (Portable Text + page-builder blocks)
//  • Decision 3 — ALL content types are core (every type has live URLs)
//
// HYBRID strategy: lift the fields we FILTER/SORT/JOIN on into typed scalar columns;
// keep rich/variable/nested structures (Portable Text, contentBlocks, keyFeatures,
// distances, investmentData, images, seo, faq) as JSONB. Faithful + queryable, without a
// 30-table sprawl. Field names mirror the Sanity schemaTypes exactly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────
enum Locale {
  en
  de
  pl
  ru
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum UserRole {
  ADMIN
  EDITOR
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  VIEWING_SCHEDULED
  OFFER
  CLOSED
  LOST
}

enum LeadSource {
  CONTACT_FORM
  PROJECT_ENQUIRY
  BLOG_ENQUIRY
  WHATSAPP
  PHONE
  REFERRAL
  MANUAL
  PARTNER
  ROI_CALCULATOR
  NEWSLETTER
  OTHER
}

enum LeadTimeline {
  IMMEDIATE
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR
  JUST_LOOKING
}

enum LeadFinancing {
  CASH
  MORTGAGE
  UNDECIDED
}

enum LeadPreferredChannel {
  EMAIL
  WHATSAPP
  PHONE
}

// Title form for formal-address languages (DE "Herr"/"Frau", PL "Pan"/"Pani").
// UNKNOWN is the default and safe fallback — Compose uses a gender-neutral
// greeting when this isn't set rather than guessing.
enum LeadSalutation {
  UNKNOWN
  MR
  MS
}

// Lead Cockpit unified timeline (Phase 1 of 4, 2026-07-23) — additive alongside
// LeadActivity, which stays untouched. See LeadInteraction below.
enum LeadInteractionType {
  EMAIL_OUT
  EMAIL_IN
  WHATSAPP_OUT
  WHATSAPP_IN
  CALL
  NOTE
  STATUS_CHANGE
  PRESENTATION_EVENT
  SYSTEM
}

enum LeadInteractionDirection {
  INBOUND
  OUTBOUND
}

enum LeadInteractionChannel {
  EMAIL
  WHATSAPP
  PHONE
  SYSTEM
}

// NOTE: property types / purposes / cities are kept as String (Sanity uses free-form
// string lists incl. values like "Semi-detached villa" that don't map cleanly to enums).

// ─── CONTENT: PROJECT (per-language row) ─────────────────────────────────────
model Project {
  id                 String        @id @default(uuid())
  sanityId           String        @unique // original per-language _id
  translationGroupId String? // from translation.metadata
  language           Locale
  slug               String // slug[language].current
  title              String
  excerpt            String?
  status             ContentStatus @default(PUBLISHED)

  // queryable scalars (lifted from keyFeatures / flags)
  city            String?
  propertyType    String?
  price           Int?
  bedrooms        String?
  completionDate  String?
  isFeatured      Boolean @default(false)
  isNew           Boolean @default(false)
  isSold          Boolean @default(false)
  listingPriority Int     @default(0)
  latitude        Float?
  longitude       Float?

  // developer (per-language reference)
  developerId String?
  developer   Developer? @relation(fields: [developerId], references: [id])

  // media (JSON; urls rewritten to local /uploads at migration)
  previewImage Json?
  images       Json?
  videoId      String?
  videoPreview Json?

  // rich content (Portable Text / objects, kept native)
  description     Json?
  fullDescription Json?
  faq             Json?
  keyFeatures     Json?
  distances       Json?
  investmentData  Json?
  seo             Json? // { metaTitle, metaDescription }

  publishedAt DateTime?
  scheduledAt DateTime? // SCHEDULED → auto-publish at this UTC instant
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  caseStudyLinks CaseStudyProject[]
  leads          Lead[]

  // Phase 5 (legacy <-> Development overlap): set when an admin confirms this
  // legacy project has been superseded by a Development. Visibility itself is
  // unaffected by this field alone — it's still controlled entirely by
  // `status` (ARCHIVED = hidden from listing/detail/sitemap, all three
  // already gate on status:"PUBLISHED"). This field only records the link,
  // for the admin banner/redirect-on-deactivate flow.
  supersededByDevelopmentId     String?
  supersededByDevelopment       Development?           @relation(fields: [supersededByDevelopmentId], references: [id])
  // Development ids an admin has explicitly rejected as a match for this legacy
  // project, from the Phase 5.2 overlap-review UI (string[] of Development.id).
  // A legacy project can have more than one candidate in the heuristic table
  // (e.g. "Kamares Village" matched two unrelated Developments), so rejection
  // is tracked per candidate, not as a single yes/no on the project itself.
  overlapRejectedDevelopmentIds Json?
  redirectTarget                LegacyProjectRedirect?

  @@unique([language, slug])
  @@index([translationGroupId])
  @@index([language, status])
  @@index([city])
  @@index([isFeatured])
  @@index([listingPriority])
  @@index([status, scheduledAt])
  @@index([supersededByDevelopmentId])
  @@map("projects")
}

// Phase 5.5: optional 301 redirect target for a deactivated (ARCHIVED) legacy
// project, typically the linked Development's live URL. Only takes effect
// while the project stays ARCHIVED (see getLegacyProjectRedirect in
// sanity.utils.ts, gated on status:"ARCHIVED") — re-activating the project
// makes this dormant again without needing to delete the row.
model LegacyProjectRedirect {
  id         String   @id @default(uuid())
  projectId  String   @unique
  targetPath String // server-relative path, e.g. "/projects/slug" or "/de/projects/slug"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("legacy_project_redirects")
}

// Generic admin action audit trail — distinct from LeadActivity (which is
// scoped to a single CRM Lead and can't represent an action like "archived 4
// legacy project rows"). Minimal by design: one row per meaningful admin
// action, enough to answer "who did what, when, to what" without a join.
model AdminAuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorName  String?
  actorEmail String?
  action     String // e.g. "batch_deactivate_confirmed_overlap"
  targetType String // e.g. "Project" (the legacy translation-group anchor)
  targetId   String
  detail     Json?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}

// One row per cron invocation (publish-scheduled | feed-sync | drive-sync),
// written in a try/finally so a run that crashes before completing still
// leaves a row (ok=false, message = the caught error) — a job that dies
// silently is exactly the failure mode Action Center rule (j) needs to catch.
// See src/lib/actionCenter/rules/system.ts for how "URGENT" is derived: latest
// row ok=false, OR no row at all within 2x the job's expected interval (catches
// a crontab that stopped firing entirely, which a pure success/failure log
// can't distinguish from "nothing to do" — the exact gap from the migration-day
// incident where cron entries were silently disabled).
model CronRunLog {
  id         String   @id @default(uuid())
  job        String // "publish-scheduled" | "feed-sync" | "drive-sync"
  ok         Boolean
  message    String? // error text, or a short summary e.g. "16 developments updated"
  durationMs Int?
  ranAt      DateTime @default(now())

  @@index([job, ranAt])
  @@map("cron_run_logs")
}

// Action Center (admin dashboard) snooze state — the only persisted piece of
// that feature; the items themselves are computed live on every dashboard load
// from existing data (see src/lib/actionCenter/). itemId is the rule's own
// stable id (derived from the entity, e.g. "sold-out:<developmentId>").
model ActionCenterSnooze {
  id           String   @id @default(uuid())
  itemId       String
  snoozedUntil DateTime
  userId       String?
  createdAt    DateTime @default(now())

  @@index([itemId])
  @@map("action_center_snoozes")
}

// ─── CONTENT: BLOG ───────────────────────────────────────────────────────────
model Blog {
  id                 String        @id @default(uuid())
  sanityId           String        @unique
  translationGroupId String?
  language           Locale
  slug               String
  title              String
  excerpt            String?
  status             ContentStatus @default(PUBLISHED)

  authorId   String?
  author     Author?   @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  previewImage      Json?
  seo               Json?
  contentBlocks     Json? // page-builder array
  videoBlock        Json?
  popularProperties Json?
  relatedArticles   Json? // refs to blog/singlepage (resolved at render)

  readingTime Int? // computed at migration/save
  publishedAt DateTime?
  scheduledAt DateTime? // SCHEDULED → auto-publish at this UTC instant
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([language, slug])
  @@index([translationGroupId])
  @@index([language, status])
  @@index([publishedAt])
  @@index([status, scheduledAt])
  @@map("blogs")
}

// ─── CONTENT: SINGLE PAGE (catch-all routes + landing pages) ─────────────────
model Singlepage {
  id                 String        @id @default(uuid())
  sanityId           String        @unique
  translationGroupId String?
  language           Locale
  slug               String // may be multi-segment (parent/child)
  title              String
  excerpt            String?
  status             ContentStatus @default(PUBLISHED)

  allowIntroBlock Boolean @default(false)
  parentSanityId  String? // parentPage reference (resolved to build nested slug)

  previewImage        Json?
  seo                 Json?
  contentBlocks       Json?
  // Editor-curated contextual links to other SAME-LANGUAGE landing pages.
  // Shape: [{ _key, _ref (target sanityId), _type: "singlepageRef" }]
  relatedLandingPages Json?

  publishedAt DateTime?
  scheduledAt DateTime? // SCHEDULED → auto-publish at this UTC instant
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([language, slug])
  @@index([translationGroupId])
  @@index([status, scheduledAt])
  @@map("singlepages")
}

// ─── CONTENT: CASE STUDY ─────────────────────────────────────────────────────
model CaseStudy {
  id                 String        @id @default(uuid())
  sanityId           String        @unique
  translationGroupId String?
  language           Locale
  slug               String
  title              String
  fullTitle          String?
  excerpt            String?
  category           String?
  status             ContentStatus @default(PUBLISHED)

  previewImage   Json?
  seo            Json?
  clientOverview Json?
  caseDetails    Json?
  mainContent    Json?

  publishedAt DateTime?
  scheduledAt DateTime? // SCHEDULED → auto-publish at this UTC instant
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  relatedProjects CaseStudyProject[]

  @@unique([language, slug])
  @@index([translationGroupId])
  @@index([status, scheduledAt])
  @@map("case_studies")
}

model CaseStudyProject {
  caseStudyId String
  projectId   String
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([caseStudyId, projectId])
  @@map("case_study_projects")
}

// ─── CONTENT: PROPERTY (resale listings) ─────────────────────────────────────
model Property {
  id                 String        @id @default(uuid())
  sanityId           String        @unique
  translationGroupId String?
  language           Locale
  slug               String
  title              String
  excerpt            String?
  status             ContentStatus @default(PUBLISHED)

  price        Int?
  address      String?
  city         String?
  district     String?
  type         String? // Apartment/Villa/...
  purpose      String? // Sale/Rent
  propertyType String? // Residential/Commercial/...
  marketType   String? // Primary/Secondary
  floorSize    Int?
  rooms        Int?
  hasParking   Boolean?
  hasPool      Boolean?
  isActual     Boolean  @default(true)
  latitude     Float?
  longitude    Float?

  previewImage Json?
  images       Json?
  videoId      String?
  videoPreview Json?
  description  Json?
  distances    Json?
  seo          Json?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([language, slug])
  @@index([translationGroupId])
  @@map("properties")
}

// ─── CONTENT: DEVELOPER (per-language; names NOT shown on frontend per copy rules) ──
model Developer {
  id                 String   @id @default(uuid())
  sanityId           String   @unique
  translationGroupId String?
  language           Locale
  slug               String
  title              String
  titleFull          String?
  excerpt            String?
  logo               Json?
  description        Json?
  seo                Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  projects Project[]

  @@unique([language, slug])
  @@index([translationGroupId])
  @@map("developers")
}

// ─── CONTENT: AUTHOR / CATEGORY (per-language, simple) ───────────────────────
model Author {
  id                 String   @id @default(uuid())
  sanityId           String   @unique
  translationGroupId String?
  language           Locale
  name               String
  position           String?
  specialization     String[] @default([])
  bio                String?
  image              Json?
  linkedin           String?
  blogs              Blog[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([translationGroupId])
  @@map("authors")
}

model Category {
  id                 String   @id @default(uuid())
  sanityId           String   @unique
  translationGroupId String?
  language           Locale
  title              String
  slug               String
  blogs              Blog[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([language, slug])
  @@index([translationGroupId])
  @@map("categories")
}

// ─── CONTENT: DOC FILE (downloadable; NOT localized — plain slug) ────────────
model DocFile {
  id        String   @id @default(uuid())
  sanityId  String   @unique
  title     String
  slug      String   @unique
  file      Json? // { url (local path), originalFilename, mimeType, size }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("doc_files")
}

// ─── SINGLETONS / SITE CONFIG (homepage, header, footer, *Page, forms) ───────
// Per-language config & page-builder docs stored generically as JSON.
model SiteDocument {
  id        String   @id @default(uuid())
  sanityId  String   @unique
  type      String // homepage|header|footer|blogPage|projectsPage|caseStudiesPage|propertiesPage|notFoundPage|formStandardDocument
  language  Locale
  data      Json
  updatedAt DateTime @updatedAt

  @@unique([type, language])
  @@index([type])
  @@map("site_documents")
}

// ─── MEDIA (catalog of migrated Sanity assets + future admin uploads) ────────
model Media {
  id               String   @id @default(uuid())
  sanityAssetId    String?  @unique // image-...-jpg / file-... ref, for migration mapping
  filename         String
  originalFilename String?
  path             String // /uploads/...
  url              String // /uploads/...
  mimeType         String?
  fileSize         Int?
  width            Int?
  height           Int?
  altText          String?
  blurDataUrl      String?
  folder           String? // optional grouping for the media library
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime @default(now())

  @@index([folder])
  @@map("media")
}

// First-class media folders so they can be created up front and persist while empty.
// A media item belongs to a folder by matching Media.folder == MediaFolder.name.
model MediaFolder {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("media_folders")
}

// ─── ADMIN USERS / SESSIONS ──────────────────────────────────────────────────
model User {
  id                     String               @id @default(uuid())
  email                  String               @unique
  password               String
  name                   String
  role                   UserRole             @default(EDITOR)
  isOwner                Boolean              @default(false) // protected super-admin account — no UI to set this; DB-level only, see actions.ts guards
  avatar                 String?
  photoPng               String? // transparent-background cutout PNG, used free-floating (no frame) in the Client Presentation closing section — distinct from the small square `avatar`
  phone                  String? // advisor's own contact number, shown large/clickable in the Client Presentation closing section (distinct from the company WhatsApp number used by the contact buttons there)
  isActive               Boolean              @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  assignedLeads          Lead[]               @relation("AssignedLeads")
  uploadedMedia          Media[]
  sessions               Session[]
  resetTokens            PasswordResetToken[]
  presentationsAsAdvisor ClientPresentation[]
  // Lead Cockpit (Phase 1 of 4, 2026-07-23) — additive back-relations only.
  emailSettings          UserEmailSettings?
  interactions           LeadInteraction[]

  @@map("users")
}

// Per-user email connection settings for the Lead Cockpit (Phase 1 of 4,
// 2026-07-23). SMTP is usable now (Part C); IMAP fields are stored now but
// unused until Phase 3 (inbound email). Passwords are AES-256-GCM ciphertext
// (see src/lib/crypto/secretBox.ts) — never plaintext, never returned to the
// client; the settings UI only ever shows a "configured ✓" state.
model UserEmailSettings {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromName        String?
  fromAddress     String?
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPasswordEnc String?
  imapHost        String?
  imapPort        Int?
  imapUser        String?
  imapPasswordEnc String?
  signature       Json? // { en?, de?, pl?, ru? } plain multiline text, one per locale
  lastTestSentAt  DateTime?
  lastTestOk      Boolean?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@map("user_email_settings")
}

// Self-service password reset — one-time, hashed, short-lived tokens.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── CRM / LEADS ─────────────────────────────────────────────────────────────
model Lead {
  id                   String                @id @default(uuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  status               LeadStatus            @default(NEW)
  source               LeadSource            @default(CONTACT_FORM)
  firstName            String
  lastName             String
  email                String
  phone                String?
  nationality          String?
  languagePreference   Locale?
  budgetMin            Int?
  budgetMax            Int?
  timeline             LeadTimeline?
  financing            LeadFinancing?
  propertyTypeInterest String[]              @default([])
  lastMatchFilters     Json? // last-used Property Matching panel filters (bedrooms/locations/propertyTypes/etc.), auto-saved so the admin sees what the client is searching for on the next visit
  message              String?
  notes                String?
  assignedToId         String?
  assignedTo           User?                 @relation("AssignedLeads", fields: [assignedToId], references: [id])
  projectInterestId    String?
  projectInterest      Project?              @relation(fields: [projectInterestId], references: [id])
  presentations        ClientPresentation[]
  pageSource           String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  utmTerm              String?
  utmContent           String?
  gclid                String?
  fbclid               String?
  referrer             String?
  telegramNotified     Boolean               @default(false)
  emailNotified        Boolean               @default(false)
  activities           LeadActivity[]
  deletedAt            DateTime? // soft delete — set via /admin/crm trash flow; excluded from all normal queries
  deletedById          String?
  // Lead Cockpit (Phase 1 of 4, 2026-07-23) — additive fields only.
  preferredChannel     LeadPreferredChannel?
  nextFollowUpAt       DateTime?
  interactions         LeadInteraction[]
  // Lead Cockpit correction batch (2026-07-23) — auto-follow-up cadence.
  // Counts automatic nextFollowUpAt writes (presentation sent/viewed, or a
  // manual Call/Note/Email/WhatsApp log), shared across ALL trigger types,
  // capped at 3 by src/lib/crm/followUpCadence.ts. Resets to 0 — starting a
  // fresh chain — whenever an interaction is logged with metadata.leadReacted
  // (or via the manual "Reset" control in the Cockpit), so a lead who
  // responds and later goes quiet again gets a fresh chain of 3, rather than
  // this being a lifetime cap.
  autoFollowUpCount    Int                   @default(0)
  // Compose batch (2026-07-24) — title form for the DE/PL formal first-contact
  // salutation ("Sehr geehrter Herr [Nachname]" / "Szanowny Panie [Nachname]").
  // Manually maintained (no reliable data source); UNKNOWN falls back to a
  // gender-neutral greeting instead of guessing. Not used for EN/RU.
  salutation           LeadSalutation        @default(UNKNOWN)

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@index([source])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(uuid())
  leadId      String
  type        String
  content     String?
  createdAt   DateTime @default(now())
  createdBy   String?
  createdById String?
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_activities")
}

// Lead Cockpit unified timeline (Phase 1 of 4, 2026-07-23) — additive, sits
// alongside LeadActivity (never altered/dropped). Populated by a one-time
// copy-migration from LeadActivity (see scripts/migrate-lead-activity-to-
// interactions.mjs, idempotent via legacyActivityId) plus, going forward, a
// parallel write at every existing leadActivity.create() call site.
model LeadInteraction {
  id               String                    @id @default(uuid())
  leadId           String
  lead             Lead                      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type             LeadInteractionType
  direction        LeadInteractionDirection?
  channel          LeadInteractionChannel?
  subject          String?
  body             String?
  occurredAt       DateTime                  @default(now())
  createdByUserId  String?
  createdByUser    User?                     @relation(fields: [createdByUserId], references: [id])
  createdByName    String? // display-name snapshot, same convention as LeadActivity.createdBy — survives user deletion
  metadata         Json?
  legacyActivityId String?                   @unique // set only on rows copy-migrated from LeadActivity; makes the migration script safe to re-run

  @@index([leadId])
  @@index([leadId, occurredAt])
  @@map("lead_interactions")
}

// ─── ANALYTICS (self-hosted) ─────────────────────────────────────────────────
model PageView {
  id          Int      @id @default(autoincrement())
  path        String
  locale      String?
  referrer    String?
  userAgent   String?
  visitorHash String? // cookieless daily-rotating hash (no IP/PII); for unique-visitor counts
  deviceType  String? // "mobile" | "tablet" | "desktop", derived from userAgent at track time
  country     String? // ISO 3166-1 alpha-2, derived from IP via GeoIP at track time; IP itself is never stored
  createdAt   DateTime @default(now())

  // Non-human/non-confirmed-view classification, all default false and all excluded from
  // analytics queries — kept distinct (rather than one flag) so the "excluded" footer count
  // and future debugging can tell them apart:
  isBot      Boolean @default(false) // matched isbot() or an explicit crawler/PSI-Lighthouse pattern at ingestion, or backfilled from stored userAgent
  isPrefetch Boolean @default(false) // Sec-Purpose/Purpose: prefetch header at ingestion (Chrome/Google Search speculative prerender that never activated for a real user), or backfilled from the dominant prefetch UA+referrer profile (see migration note)
  isTest     Boolean @default(false) // our own synthetic verification beacons (?test=1 / X-Analytics-Test header)

  @@index([path])
  @@index([createdAt])
  @@index([visitorHash])
  @@map("page_views")
}

// ─── AUTOMATION LAYER (future-ready, created empty) ──────────────────────────
model FeedSource {
  id          String    @id @default(uuid())
  name        String
  url         String
  type        String
  isActive    Boolean   @default(true)
  lastFetched DateTime?
  lastStatus  String?
  errorLog    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncLogs    SyncLog[]

  @@map("feed_sources")
}

model SyncLog {
  id              String     @id @default(uuid())
  feedSourceId    String
  startedAt       DateTime   @default(now())
  completedAt     DateTime?
  status          String
  recordsFound    Int?
  recordsCreated  Int?
  recordsUpdated  Int?
  recordsArchived Int?
  errorMessage    String?
  feedSource      FeedSource @relation(fields: [feedSourceId], references: [id])

  @@map("sync_logs")
}

model AiGenerationQueue {
  id          String    @id @default(uuid())
  entityType  String
  entityId    String
  locale      Locale
  prompt      String?
  status      String    @default("PENDING")
  result      Json?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@map("ai_generation_queue")
}

// ─────────────────────────────────────────────────────────────────────────
// DEVELOPER FEED ANALYSIS — discovery / standardization tool (v1).
// Fully additive and ISOLATED: no relations to Project / Property / Developer /
// Lead / anything existing. Stores a developer identity plus the result of
// analyzing an uploaded XML file or a feed URL. Nothing here reads from or
// writes to public content. DeveloperAccount 1─▶ N DeveloperFeedAnalysis.
// ─────────────────────────────────────────────────────────────────────────

model DeveloperAccount {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  website           String?
  contactInfo       String?
  contactPerson     String? // Ansprechpartner
  phone             String?
  email             String?
  developerCloudUrl String? // login/cloud portal link
  driveFolderUrl    String? // Google/OneDrive shared folder used as a no-feed source
  driveFileId       String? // last price file synced (Drive file id)
  driveFileModified String? // that file's modifiedTime — skip sync when unchanged
  driveSyncedAt     DateTime? // last successful drive availability sync
  driveSyncInterval String?   @default("daily") // daily | 2day | weekly | off
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  analyses     DeveloperFeedAnalysis[]
  developments Development[]

  @@map("developer_accounts")
}

model DeveloperFeedAnalysis {
  id                 String   @id @default(uuid())
  developerAccountId String
  sourceType         String // "FILE" | "URL" | "API"
  sourceUrl          String? // "URL": feed URL; "API": full request URL (non-secret)
  sourceFileName     String? // original filename when sourceType = "FILE"
  rawXml             String? // retained raw payload (XML or JSON), size-capped, for re-analysis; String → Postgres text
  sourceConfig       Json? // "API" request recipe (method/auth/headerName/body/credentialRef) — NEVER the secret itself
  itemNodePath       String? // detected repeating item node, e.g. "properties.property" or a JSON path
  itemCount          Int      @default(0)
  fields             Json? // analyzed + manually-edited field list (array of field descriptors)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  developerAccount DeveloperAccount @relation(fields: [developerAccountId], references: [id], onDelete: Cascade)

  @@index([developerAccountId])
  @@map("developer_feed_analyses")
}

// ─────────────────────────────────────────────────────────────────────────
// FEED-DRIVEN DEVELOPMENTS (Phase 1). Additive + isolated: the 24h sync writes
// Development/DevelopmentUnit from the developer feeds (see src/app/preview-project/
// feeds.ts adapters → canonical ProjectVM). Admin edits live in DevelopmentOverride
// and ALWAYS win over feed values; the sync never touches overrides. Images are
// mirrored to our object storage; only our URLs are stored here.
// ─────────────────────────────────────────────────────────────────────────
model Development {
  id                 String  @id @default(uuid())
  developerAccountId String
  dev                String // adapter key: island-blue|inex|bbf|aristo|pafilia|domenica|medousa|agg
  feedProjectId      String // id/name within the feed
  feedKey            String  @unique // "<dev>:<feedProjectId>", e.g. "inex:1"
  slug               String? @unique // SEO-facing URL slug (english, kebab-case), set on publish — see src/lib/developmentSeo.ts

  // feed-derived scalars (filter/sort)
  developerName  String // original project name from the feed
  publicName     String // feed name (admin alias → DevelopmentOverride)
  developer      String? // display developer label
  category       String?
  status         String?
  stage          String?
  completion     String?
  energy         String?
  district       String?
  town           String?
  area           String?
  priceFrom      Int?
  priceTo        Int?
  currency       String? @default("EUR")
  latitude       Float?
  longitude      Float?
  unitsTotal     Int     @default(0)
  unitsAvailable Int     @default(0)

  // rich/nested (JSONB) — feed values; images already mirrored to our storage
  description String? // feed description (plain text)
  amenities   Json? // string[]
  gallery     Json? // [{ small, medium, large }] mirrored
  plans       Json?
  extraFacts  Json? // [{ label, value }]
  // Auto-computed (haversine, no AI/external API) from resolved coordinates
  // (override lat/lng -> this row's own) — { beach, restaurants, shops,
  // airport, hospital, school, cityCenter, golf }, minutes, keys >60min or
  // unresolvable omitted entirely. See src/lib/developmentDistances.ts, the
  // single source of truth every write path (feedSync, driveAvailabilitySync,
  // admin map-location save, the one-off backfill script) recomputes through.
  distances   Json?

  // sync + publication lifecycle
  syncedAt            DateTime?
  driveFolderId       String? // Drive project subfolder (for image/plan import)
  driveImagesModified String? // signature of the mirrored images — skip when unchanged
  publishStatus       String    @default("draft") // draft | ready | published | archived
  publishedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  developerAccount   DeveloperAccount         @relation(fields: [developerAccountId], references: [id], onDelete: Cascade)
  units              DevelopmentUnit[]
  override           DevelopmentOverride?
  presentationItems  ClientPresentationItem[]
  supersedesProjects Project[]

  @@index([developerAccountId])
  @@index([publishStatus])
  @@index([district, area])
  @@map("developments")
}

model DevelopmentUnit {
  id              String   @id @default(uuid())
  developmentId   String
  ref             String?
  name            String?
  label           String? // display label, e.g. "Block C · Nr. 504"
  type            String?
  status          String?  @default("available") // available | reserved | sold
  price           Int?
  currency        String?  @default("EUR")
  beds            String?
  baths           String?
  areaBuilt       String? // total built area
  areaInternal    String? // covered internal area
  areaPlot        String?
  areaVeranda     String? // covered veranda
  areaVerandaOpen String? // uncovered veranda
  floor           String? // level / floor
  unitNumber      String?
  storage         String? // yes | no
  guestWc         String? // yes | no
  orientation     String?
  latitude        Float?
  longitude       Float?
  attrs           Json? // [{ name, value }] extra spec
  amenities       Json? // per-unit amenities (Sea View, VRV, corner …)
  photos          Json? // [{ small, medium, large }] mirrored
  plans           Json?
  sortIndex       Int      @default(0)
  source          String   @default("feed") // feed | manual — sync only ever wipes/rewrites "feed" units
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@index([developmentId])
  @@map("development_units")
}

// Admin overrides — win over feed values at render time; sync never writes here.
model DevelopmentOverride {
  id            String   @id @default(uuid())
  developmentId String   @unique
  alias         String? // public name override
  district      String?
  town          String?
  area          String? // corrected marketing area (e.g. micro-quarter → Kato Paphos)
  mainImage     String? // admin-selected hero (mirrored URL)
  gallery       Json? // admin-managed ordered gallery (reorder/delete/upload); wins over feed gallery
  heroVideo     String? // uploaded loop (mirrored URL)
  descriptionEN String?
  descriptionDE String?
  descriptionPL String?
  descriptionRU String?
  amenities     Json? // admin-checked amenities merged with feed ones
  vatApplies    Boolean? // null = follow feed; true/false = admin decision (e.g. renovated no-VAT)
  completion    String?
  energy        String?
  // Construction-stage override (Available | Under Construction | Key-Ready | Sold).
  // Moved here 2026-07-18 from Development.stage: that column is ALSO written by
  // feedSync.ts on every sync for feed-based developers (qubehub/INEX/BBF sets a
  // real feed-derived stage; island-blue etc. have no stage field and always sync
  // it back to null) — an admin's manual choice on the same column was silently
  // wiped by the next day's sync (Celestia, 2026-07-17/18). Same protection every
  // other admin-editable field here already has: sync never writes to this table.
  // Resolution everywhere is `ov?.stage || d.stage` (override wins, raw feed value
  // is the fallback for developers whose feed genuinely provides one).
  stage         String?
  latitude      Float? // admin-set map coordinates (win over feed); parsed from a Maps link or lat,lng
  longitude     Float?
  seo           Json? // optional per-language SEO overrides: { titleEN/DE/PL/RU, descEN/DE/PL/RU } — empty/missing = auto-generated (see src/lib/developmentSeo.ts)
  updatedAt     DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@map("development_overrides")
}

// Reusable neighbourhood copy — one per area, shared by all developments there.
model AreaDescription {
  id        String   @id @default(uuid())
  areaSlug  String   @unique // normalized area key (lowercase, ph→f)
  areaName  String
  district  String?
  textEN    String?
  textDE    String?
  textPL    String?
  textRU    String?
  source    String   @default("manual") // ai | manual
  status    String   @default("draft") // draft | approved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("area_descriptions")
}

// Google Search Console daily metrics — synced by /api/cron/gsc-sync (05:30
// daily, backfills 90 days on first run, then upserts the last 3 days since
// GSC's own data lags ~2 days). Two row shapes share this table:
//   - page-level rows (query = null): one row per (date, page, locale), the
//     GSC-reported aggregate for that page — this is what Action Center rules
//     and the admin SEO view read (position/CTR here are GSC's own numbers,
//     NOT derivable by summing query-level rows below).
//   - query-level rows (query set): one row per (date, page, locale, query),
//     the finer breakdown — stored for future use (query-level insight, the
//     Advisor layer), not consumed by any rule/view built so far.
// `page` is the raw URL path as GSC reports it (includes the locale prefix
// for de/pl/ru, no prefix for en) — `locale` is derived from that path at
// ingestion time, purely for filtering/segmentation.
// Retention: purged after 16 months (matches GSC's own retention) by the same
// cron, piggybacking the pattern used elsewhere (see feed-sync's purge*
// functions) rather than a separate scheduled job.
// Note: Postgres allows multiple rows with the same (date, page, locale, NULL)
// combination since NULL != NULL in a unique index — uniqueness for
// page-level rows is enforced by always going through upsert in application
// code, not by the DB constraint alone.
model SearchMetric {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  page        String
  locale      Locale
  query       String? // null = page-level row; set = per-query breakdown row
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, page, locale, query])
  @@index([page, locale, date])
  @@index([date])
  @@map("search_metrics")
}

// Core Web Vitals — synced nightly by /api/cron/psi-sync (02:00, before the
// GSC sync window) from the free PageSpeed Insights API (mobile strategy).
// `source` records whether this row is real CrUX field data (28-day rolling
// user data, preferred) or a Lighthouse lab-run fallback (used when a URL
// doesn't have enough real-user traffic for CrUX to report on it — common for
// low-traffic Development pages). `url` is the full path queried (matches
// SearchMetric's `page` convention: locale-prefixed for de/pl/ru, unprefixed
// for en). Retention: 12 months, purged by the same cron.
model CwvMetric {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  url       String
  lcp       Float // ms
  cls       Float
  inp       Float? // ms — not always available (older Lighthouse versions, or CrUX not yet reporting it)
  perfScore Int // Lighthouse performance score, 0-100
  source    String // "field" | "lab"
  createdAt DateTime @default(now())

  @@unique([date, url])
  @@index([url, date])
  @@map("cwv_metrics")
}

// One row per weekly SEO Advisor run (src/lib/seoAdvisor/run.ts, cron Sundays
// 06:00 UTC). `suggestions` is the full array from the LLM's analysis, each
// entry carrying its own lifecycle state — no separate suggestions table, per
// spec: { id, fingerprint, title, rationale, action, impactEstimate, effort,
// category, status: "open"|"approved"|"dismissed", dismissCount, preparedPrompt? }.
// `fingerprint` (sha256 of category+normalized title) is computed AFTER the
// LLM responds, not asked of the model — an LLM can't be trusted to emit a
// stable id for "the same suggestion" across separate weekly runs, but a
// deterministic hash of its own (category, title) can be compared across runs
// for the 90-day dismiss-twice suppression rule (see seoAdvisor/suppression.ts).
// `telegramSentAt` makes the Monday-digest piggyback (see action-digest cron)
// idempotent — a run's summary is sent exactly once, whichever daily digest
// fires next after this run completes.
model AdvisorRun {
  id             String    @id @default(uuid())
  runDate        DateTime  @default(now())
  payloadHash    String
  suggestions    Json
  telegramSentAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([runDate])
  @@map("advisor_runs")
}

// Global, admin-editable AI prompt templates — shared across ALL projects (one
// row per feature), editable from within any project's own page via "Adjust
// prompt" rather than a separate settings screen. `key` namespaces features the
// same way PromptTuner's localStorage `presetKey` does (e.g. "seoMeta" for the
// Development SEO title/description generator) — extensible to future features.
model AiPromptTemplate {
  id        String   @id @default(uuid())
  key       String   @unique
  template  String
  updatedAt DateTime @updatedAt

  @@map("ai_prompt_templates")
}

// ─────────────────────────────────────────────────────────────────────────
// CLIENT PRESENTATION SYSTEM — a personal, token-protected property selection
// page generated from a CRM lead + curated Development matches. Public page:
// src/app/c/[token]/page.tsx (no locale prefix, always noindex). Admin entry
// point: the "Property Matching" section on src/app/admin/(panel)/crm/[id]/page.tsx.
// ─────────────────────────────────────────────────────────────────────────

model ClientPresentation {
  id              String    @id @default(uuid())
  leadId          String
  token           String    @unique // 12+ char URL-safe crypto-random, see src/lib/crm/presentationToken.ts
  status          String    @default("active") // active | expired | revoked
  locale          Locale    @default(en)
  greetingName    String // how the client is addressed, editable
  personalNote    String? // optional message from advisor, shown as a signed blockquote
  filterBedrooms  Int[]     @default([]) // DEPRECATED — superseded by criteria.bedrooms; kept read-only, see backfill migration
  filterLocations String[]  @default([]) // DEPRECATED — superseded by criteria.districts/areas; kept read-only, see backfill migration
  criteria        Json? // { districts, areas, bedrooms, budgetMin, budgetMax, propertyTypes } — the actual matching-panel filter state at generation time (or last edit-save). The public page's "your preferences" chips render EXCLUSIVELY from this, never from Lead fields directly — a lead's own profile (budget/type) can differ from what was actually searched for this specific presentation.
  advisorId       String? // User relation — whose contact card shows in the closing section
  advisor         User?     @relation(fields: [advisorId], references: [id])
  expiresAt       DateTime? // default now + 30 days, extendable from the admin
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lead  Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  items ClientPresentationItem[]
  views PresentationView[]

  @@index([leadId])
  @@map("client_presentations")
}

model ClientPresentationItem {
  id             String    @id @default(uuid())
  presentationId String
  developmentId  String
  unitIds        Json? // DEPRECATED — DevelopmentUnit UUIDs, orphaned by feed re-syncs (units wiped/recreated). Kept read-only for units with no ref (manual units, stable UUIDs). No longer written to; see unitRefs.
  unitRefs       Json? // array of normalizeRef()'d unit refs (src/lib/unitRef.ts) — stable across feed re-syncs, resolved against Development.units at render time. null = all available units
  sortIndex      Int       @default(0)
  advisorComment String? // one-line personal note per property, optional
  isFavorited    Boolean   @default(false) // client clicked the heart
  favoritedAt    DateTime?
  aliasName      String? // per-presentation display name override, wins over DevelopmentOverride.alias and Development.publicName
  isNew          Boolean   @default(false) // "New for you" badge — set when added via the edit page, cleared on first overlay view
  newAddedAt     DateTime?

  presentation ClientPresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  development  Development        @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@unique([presentationId, developmentId])
  @@map("client_presentation_items")
}

model PresentationView {
  id             String   @id @default(uuid())
  presentationId String
  sessionHash    String // same cookieless daily-rotating approach as PageView, see src/lib/visitorHash.ts
  developmentId  String? // null = page-level view; set = a specific property card/overlay opened
  durationSec    Int? // sent via sendBeacon on close/hide, best effort
  createdAt      DateTime @default(now())

  presentation ClientPresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([createdAt])
  @@map("presentation_views")
}
